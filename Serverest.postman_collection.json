              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"nome\": \"{{NOME_PRODUTO}} EDITADO\",\r\n  \"preco\": 150,\r\n  \"descricao\": \"Produto atualizado via Postman\",\r\n  \"quantidade\": 20\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
